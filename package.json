{
  "name": "traceforge",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "test": "bun run --filter='*' test",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  }
}
