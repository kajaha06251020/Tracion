# Database
TRACEFORGE_DATABASE_URL=postgresql://traceforge:traceforge@localhost:5432/traceforge

# Redis
TRACEFORGE_REDIS_URL=redis://localhost:6379

# API key for SDK ingest
TRACEFORGE_API_KEY=

# OAuth providers (for Better Auth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web app URL (used for CORS + OAuth callback)
TRACEFORGE_WEB_URL=http://localhost:3000

# Better Auth secret (random 32+ char string)
BETTER_AUTH_SECRET=

# Port
PORT=3001

# GitHub PR auto-comment (optional)
# Create a personal access token (classic) with "repo" scope, OR
# a fine-grained PAT with "Issues: Read and Write" permission.
# See: https://github.com/settings/tokens
GITHUB_TOKEN=

# Slack notifications (optional)
# Create an Incoming Webhook in your Slack workspace:
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
